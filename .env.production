# Production environment for Singgah backend (deploy to singgah-api.predev.my.id)
# Copy this file to .env on the production server and fill in the real secrets.

# MySQL
DB_ROOT_PASSWORD=CHANGE_ME
DB_NAME=singgah_admin
DATABASE_URL=mysql+pymysql://singgah_admin:CHANGE_ME@103.52.212.190:3306/singgah_admin

# App
PROJECT_NAME=Singgah SmartAdvisor

# OpenRouter / LLM
API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-3.5-turbo
LLM_URL=https://openrouter.ai/api/v1

# Frontend URL (used by build pipeline)
REACT_APP_API_URL=https://singgah-api.predev.my.id/

# Allowed frontend origins for CORS
CORS_ORIGINS=https://predev.my.id,https://www.predev.my.id

# WhatsApp gateway (wagw.cvmedandigitalinovasi.com)
WA_TOKEN=CHANGE_ME
