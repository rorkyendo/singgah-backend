# Copy this file to .env and fill in the real values before running deploy.

# MySQL
DB_ROOT_PASSWORD=root
DB_NAME=singgah_chat
DATABASE_URL=mysql+pymysql://root:root@db:3306/singgah_chat

# App
PROJECT_NAME=Singgah SmartAdvisor

# OpenRouter / LLM
API_KEY=sk-or-v1-...
LLM_MODEL=openai/gpt-3.5-turbo
LLM_URL=https://openrouter.ai/api/v1

# Frontend API URL (must end with a trailing slash)
# Local: http://localhost:8000/
# Production: https://singgah-api.predev.my.id/
REACT_APP_API_URL=http://localhost:8000/

# Allowed frontend origins for CORS. Use "*" for development only.
# Production: https://predev.my.id,https://www.predev.my.id
CORS_ORIGINS=*

# WhatsApp gateway (wagw.cvmedandigitalinovasi.com)
WA_TOKEN=your_wa_gateway_token_here
